{
  "name": "stamp",
  "version": "0.1.0",
  "private": true,
  "author": "MONGRLZ",
  "description": "Wallet-native closest-match fingerprint pools settled by TxLINE multiproofs on Solana.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx scripts/dev.ts",
    "web:dev": "vite --config apps/web/vite.config.ts",
    "web:build": "vite build --config apps/web/vite.config.ts",
    "build": "anchor build && npm run idl:sync",
    "build:test-programs": "anchor build -p mock_txline && anchor build -p stamp -- --features mock-oracle && npm run idl:sync",
    "idl:sync": "mkdir -p packages/stamp-sdk/src/idl && cp target/idl/stamp.json packages/stamp-sdk/src/idl/stamp.json",
    "check": "cargo check --workspace --all-targets",
    "test": "npm run test:unit",
    "test:unit": "cargo test --workspace && tsx --test tests/**/*.test.ts",
    "test:local": "bash scripts/test-local.sh",
    "test:anchor": "tsx tests/stamp.ts",
    "lint": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "format": "cargo fmt --all",
    "keeper:settle": "node --env-file-if-exists=.env --import tsx services/keeper/src/settle.ts",
    "keeper:daemon": "node --env-file-if-exists=.env --import tsx services/keeper/src/daemon.ts",
    "keeper:once": "node --env-file-if-exists=.env --import tsx services/keeper/src/daemon.ts --once",
    "keeper:finalize": "node --env-file-if-exists=.env --import tsx services/keeper/src/finalize.ts",
    "wallet:claim": "node --env-file-if-exists=.env --import tsx services/wallet/src/claim.ts",
    "api:start": "node --env-file-if-exists=.env --import tsx services/api/src/main.ts",
    "devnet:faucet": "tsx scripts/devnet-faucet.ts",
    "devnet:seed-pool": "tsx scripts/seed-devnet-pool.ts",
    "devnet:verify-txline": "tsx scripts/verify-real-txline.ts",
    "devnet:smoke": "tsx scripts/smoke-devnet.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@solana/spl-token": "0.4.14",
    "@solana/wallet-standard-features": "1.4.0",
    "@solana/web3.js": "1.98.4",
    "@wallet-standard/app": "1.1.1",
    "@wallet-standard/base": "1.1.1",
    "@wallet-standard/features": "1.1.1",
    "bn.js": "5.2.5",
    "buffer": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/bn.js": "5.2.0",
    "@types/node": "24.0.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.3",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vite": "^8.1.5"
  }
}

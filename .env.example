# Public Solana configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
STAMP_PROGRAM_ID=7Xh5gJZN2SoYmDLsVQKtqFoB8pxrvykn9S8hjFWguE5o
TXLINE_ORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J

# Server-only TxLINE credentials. Never expose these to a browser bundle.
TXLINE_BASE_URL=
TXLINE_JWT=
TXLINE_API_TOKEN=
# Optional local JSON with { base, jwt, apiToken }; overrides the three values above.
TXLINE_TOKEN_FILE=

# Keeper only pays transaction fees and submits public proofs. It cannot choose
# winners or redirect pool funds. Prefer a dedicated low-balance devnet keypair.
KEEPER_KEYPAIR_PATH=
KEEPER_POOL_ADDRESSES=
KEEPER_POLL_INTERVAL_MS=15000

# Read-only API service
API_HOST=127.0.0.1
API_PORT=8787
API_CORS_ORIGIN=*
